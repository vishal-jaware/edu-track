<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>

  <style>
/* GLOBAL  */
body {
  font-family: 'Segoe UI', sans-serif;
  background: #111;
  color: white;
  margin: 0;
}

/* NAVBAR  */
.navbar {
  background: #1b1b1b;
  padding: 15px 20px;
  border-bottom: 1px solid #333;
  position: sticky;
  top: 0;
  z-index: 1000;
}

.navbar-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1200px;
  margin: auto;
  position: relative;
}

/* LOGO */
.logo a {
  color: #ff9800;
  font-size: 20px;
  font-weight: bold;
  text-decoration: none;
}

/* NAV LINKS */
.nav-links {
  list-style: none;
  display: flex;
  gap: 20px;
  margin: 0;
  padding: 0;
}

.nav-links a {
  text-decoration: none;
  color: #ddd;
  transition: 0.3s;
}

.nav-links a:hover {
  color: #ff9800;
}

/* HAMBURGER */
.hamburger {
  display: none;
  font-size: 26px;
  color: #ff9800;
  cursor: pointer;
}

/* MOBILE  */
@media (max-width: 768px) {

  .hamburger {
    display: block;
  }

  .nav-links {
    position: absolute;
    top: 60px;
    left: 0;
    width: 100%;
    background: #222;
    flex-direction: column;
    text-align: center;
    display: none;
    padding: 10px 0;
  }

  .nav-links.active {
    display: flex;
  }
}

/* PAGE  */
.register-page {
  min-height: 80vh;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 50px 20px;
}

/* CONTAINER */
.form-container {
  background: #1b1b1b;
  padding: 40px;
  border-radius: 12px;
  width: 100%;
  max-width: 800px;
  border: 1px solid #333;
  box-shadow: 0 10px 30px rgba(0,0,0,0.6);
}

/* TITLE */
.form-container h2 {
  text-align: center;
  color: #ff9800;
  margin-bottom: 30px;
}

/* GRID */
.dashboard-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 25px;
}

/* CARD */
.dashboard-card {
  background: #222;
  padding: 25px;
  border-radius: 10px;
  border-left: 4px solid #ff9800;
  text-align: center;
  transition: 0.3s;
}

.dashboard-card:hover {
  transform: translateY(-6px);
}

/* BUTTON */
.btn-small {
  display: inline-block;
  padding: 10px 16px;
  background: #ff9800;
  color: white;
  border-radius: 6px;
  text-decoration: none;
  margin-top: 10px;
}

.btn-small:hover {
  background: #e68900;
}

/* MOBILE PAGE */
@media (max-width: 768px) {
  .dashboard-cards {
    grid-template-columns: 1fr;
  }
}
  </style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="navbar-container">
    <div class="logo"><a href="/">EduTrack Admin</a></div>

    <div class="hamburger" id="hamburger">☰</div>

    <ul class="nav-links" id="nav-links">
      <li><a href="/admin">Dashboard</a></li>
      <li><a href="/course">Add Course</a></li>
      <li><a href="/manage-courses">Manage Courses</a></li>
      <li><a href="/logout">Logout</a></li>
    </ul>
  </div>
</nav>

<!-- PAGE -->
<section class="register-page">
  <div class="form-container">
    <h2>Admin Dashboard</h2>

    <div class="dashboard-cards">

      <div class="dashboard-card">
        <h3>View All Courses</h3>
        <a href="/manage-courses" class="btn-small">Go to Courses</a>
      </div>

      <div class="dashboard-card">
        <h3>Add New Course</h3>
        <a href="/course" class="btn-small">Create Course</a>
      </div>

    </div>
  </div>
</section>

<!-- JS -->
<script>
const hamburger = document.getElementById("hamburger");
const navLinks = document.getElementById("nav-links");

hamburger.addEventListener("click", () => {
  navLinks.classList.toggle("active");
});

// close after click
document.querySelectorAll("#nav-links a").forEach(link => {
  link.addEventListener("click", () => {
    navLinks.classList.remove("active");
  });
});
</script>

</body>
</html>