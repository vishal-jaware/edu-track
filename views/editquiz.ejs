<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Edit Quiz</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>

/* ===== BODY ===== */

body{
margin:0;
font-family:Arial, Helvetica, sans-serif;
background:#111;
color:white;
}

/* ===== NAVBAR ===== */

.navbar{
background:#1b1b1b;
border-bottom:1px solid #333;
}

.navbar-container{
max-width:1200px;
margin:auto;
display:flex;
justify-content:space-between;
align-items:center;
padding:15px 20px;
}

.logo a{
color:#ff9800;
font-size:20px;
font-weight:bold;
text-decoration:none;
}

.nav-links{
list-style:none;
display:flex;
gap:25px;
margin:0;
padding:0;
}

.nav-links a{
text-decoration:none;
color:#ccc;
font-size:14px;
}

.nav-links a:hover{
color:#ff9800;
}

/* ===== HAMBURGER ===== */

.hamburger{
display:none;
cursor:pointer;
font-size:22px;
color:white;
}

/* ===== MOBILE ===== */

@media(max-width:768px){

.nav-links{
position:absolute;
top:60px;
right:0;
background:#1b1b1b;
width:200px;
flex-direction:column;
align-items:center;
display:none;
padding:20px 0;
}

.nav-links.show{
display:flex;
}

.hamburger{
display:block;
}

}

/* ===== FORM SECTION ===== */

.register-page{
min-height:80vh;
display:flex;
justify-content:center;
align-items:center;
padding:40px 20px;
}

/* ===== FORM CONTAINER ===== */

.form-container{
background:#1b1b1b;
padding:35px;
border-radius:12px;
width:100%;
max-width:500px;
border:1px solid #333;
box-shadow:0 10px 25px rgba(0,0,0,0.6);
}

.form-container h2{
text-align:center;
color:#ff9800;
margin-bottom:25px;
}

/* ===== FORM GROUP ===== */

.form-group{
display:flex;
flex-direction:column;
margin-bottom:18px;
}

.form-group label{
color:#bbb;
margin-bottom:6px;
font-size:14px;
}

.form-group input{
padding:10px;
border-radius:6px;
border:1px solid #333;
background:#222;
color:white;
}

.form-group input:focus{
outline:none;
border-color:#ff9800;
}

/* ===== BUTTON ===== */

.btn{
width:100%;
padding:12px;
background:#ff9800;
border:none;
border-radius:6px;
color:white;
font-weight:600;
cursor:pointer;
margin-top:10px;
}

.btn:hover{
background:#e68900;
}

/* ===== BACK BUTTON ===== */

.btn-outline{
display:inline-block;
margin-top:15px;
padding:10px 18px;
border:2px solid #ff9800;
color:#ff9800;
text-decoration:none;
border-radius:6px;
transition:0.3s;
text-align:center;
}

.btn-outline:hover{
background:#ff9800;
color:white;
}

/* ===== FOOTER ===== */

.footer{
background:#1b1b1b;
border-top:1px solid #333;
padding:20px;
text-align:center;
margin-top:40px;
}

.footer-logo{
color:#ff9800;
font-weight:bold;
margin-bottom:5px;
}

.footer-text{
color:#aaa;
font-size:13px;
}

</style>

</head>

<body>

<!-- ===== NAVBAR ===== -->

<nav class="navbar">
<div class="navbar-container">

<div class="logo">
<a href="/">EduTrack Admin</a>
</div>

<div class="hamburger" id="hamburger">☰</div>

<ul class="nav-links" id="navLinks">
<li><a href="/admin">Dashboard</a></li>
<li><a href="/course">Add Course</a></li>
<li><a href="/manage-courses">Manage Courses</a></li>
<li><a href="/logout">Logout</a></li>
</ul>

</div>
</nav>


<!-- ===== EDIT QUIZ FORM ===== -->

<section class="register-page">

<div class="form-container">

<h2>Edit Quiz Question</h2>

<form action="/edit-quiz/<%= quiz.qid %>" method="POST">

<div class="form-group">
<label>Question</label>
<input type="text" name="name" value="<%= quiz.name %>" required>
</div>

<div class="form-group">
<label>Option 1</label>
<input type="text" name="options" value="<%= quiz.options[0] %>" required>
</div>

<div class="form-group">
<label>Option 2</label>
<input type="text" name="options" value="<%= quiz.options[1] %>" required>
</div>

<div class="form-group">
<label>Option 3</label>
<input type="text" name="options" value="<%= quiz.options[2] %>">
</div>

<div class="form-group">
<label>Option 4</label>
<input type="text" name="options" value="<%= quiz.options[3] %>">
</div>

<div class="form-group">
<label>Correct Answer</label>
<input type="text" name="answer" value="<%= quiz.answer %>" required>
</div>

<button type="submit" class="btn">Update Question</button>

</form>

<a href="/manage-quiz/<%= quiz.mid %>" class="btn-outline">Back to Quiz</a>

</div>

</section>


<!-- ===== FOOTER ===== -->

<footer class="footer">

<div class="footer-logo">LMS Admin</div>

<p class="footer-text">
&copy; <%= new Date().getFullYear() %> LMS. All rights reserved.
</p>

</footer>


<script>

const hamburger = document.getElementById("hamburger");
const navLinks = document.getElementById("navLinks");

hamburger.addEventListener("click", () => {
navLinks.classList.toggle("show");
});

</script>

</body>
</html>