<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Edit Module</title>

<style>

/* GLOBAL  */
body{
  background:#111;
  font-family:Arial, Helvetica, sans-serif;
  margin:0;
  color:white;
}

/* NAVBAR  */
.navbar{
  background:#1b1b1b;
  border-bottom:1px solid #333;
}

.navbar-container{
  max-width:1200px;
  margin:auto;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:15px 20px;
  position:relative;
}

.logo a{
  color:#ff9800;
  font-size:20px;
  font-weight:bold;
  text-decoration:none;
}

/* NAV LINKS */
.nav-links{
  list-style:none;
  display:flex;
  gap:20px;
  margin:0;
  padding:0;
}

.nav-links a{
  text-decoration:none;
  color:#ccc;
}

.nav-links a:hover{
  color:#ff9800;
}

/* HAMBURGER */
.hamburger{
  display:none;
  font-size:26px;
  color:#ff9800;
  cursor:pointer;
}

/* MOBILE NAV */
@media(max-width:768px){

  .hamburger{
    display:block;
  }

  .nav-links{
    position:absolute;
    top:60px;
    left:0;
    width:100%;
    background:#222;
    flex-direction:column;
    text-align:center;
    display:none;
    padding:10px 0;
  }

  .nav-links.active{
    display:flex;
  }
}

/* PAGE  */

.edit-page{
  padding:80px 20px;
  display:flex;
  justify-content:center;
  align-items:center;
  min-height:80vh;
}

/* FORM BOX */

.edit-container{
  background:#1b1b1b;
  padding:40px;
  border-radius:10px;
  width:100%;
  max-width:420px;
  border:1px solid #333;
}

.edit-container h2{
  text-align:center;
  color:#ff9800;
  margin-bottom:25px;
}

/* LABEL */

.edit-container label{
  color:#bbb;
  font-size:14px;
}

/* INPUT */

.edit-container input,
.edit-container textarea{
  width:100%;
  padding:10px;
  margin-top:6px;
  margin-bottom:15px;
  border-radius:6px;
  border:1px solid #333;
  background:#222;
  color:white;
}

.edit-container textarea{
  min-height:90px;
  resize:vertical;
}

/* BUTTON */

button{
  width:100%;
  padding:12px;
  background:#ff9800;
  border:none;
  border-radius:6px;
  color:white;
  cursor:pointer;
  font-size:15px;
}

button:hover{
  background:#e68900;
}

</style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="navbar-container">

    <div class="logo">
      <a href="/">EduTrack Admin</a>
    </div>

    <div class="hamburger" id="hamburger">☰</div>

    <ul class="nav-links" id="nav-links">
      <li><a href="/admin">Dashboard</a></li>
      <li><a href="/course">Add Course</a></li>
      <li><a href="/manage-courses">Manage Courses</a></li>
      <li><a href="/logout">Logout</a></li>
    </ul>

  </div>
</nav>

<!-- PAGE -->
<section class="edit-page">

<div class="edit-container">

<h2>Edit Module</h2>

<form action="/edit-module/<%= module._id %>" method="POST">

<label>Module Name</label>
<input type="text" name="name" value="<%= module.name %>" required/>

<label>Description</label>
<textarea name="description" required><%= module.description %></textarea>

<label>Duration</label>
<input type="text" name="duration" value="<%= module.duration %>" required/>

<button type="submit">Update Module</button>

</form>

</div>

</section>

<script>
const hamburger = document.getElementById("hamburger");
const navLinks = document.getElementById("nav-links");


hamburger.addEventListener("click", () => {
  navLinks.classList.toggle("active");
});


document.querySelectorAll("#nav-links a").forEach(link => {
  link.addEventListener("click", () => {
    navLinks.classList.remove("active");
  });
});
</script>

</body>
</html>