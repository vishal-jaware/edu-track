<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>EduTrack</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/styles.css">
<link rel="stylesheet" href="/footer.css">

</head>

<body>

<%- include("nav") %>

<!-- HERO -->

<section class="hero">
<div class="container text-center">

<h1 class="hero-title">Learn Smarter with EduTrack</h1>

<p class="hero-text">
A simple and powerful platform for students and instructors to manage courses and learning.
</p>

<% if(!username){ %>
<a href="/register" class="btn-main">Get Started</a>
<% } %>

</div>
</section>


<!-- FEATURES -->

<section class="features">

<div class="container">

<h2 class="section-title text-center">Why Choose EduTrack</h2>

<div class="row g-4 mt-3">

<div class="col-md-4">
<div class="feature-card">
<h4>📚 Learn Easily</h4>
<p>Browse courses, enroll instantly and track your learning progress.</p>
</div>
</div>

<div class="col-md-4">
<div class="feature-card">
<h4>👨‍🏫 Teach Smarter</h4>
<p>Create courses, upload lessons and manage students effortlessly.</p>
</div>
</div>

<div class="col-md-4">
<div class="feature-card">
<h4>⚡ Fast & Simple</h4>
<p>Clean interface designed for speed and productivity.</p>
</div>
</div>

</div>

</div>

</section>


<!-- COURSES -->

<section class="courses">

<div class="container">

<h2 class="section-title text-center">Popular Courses</h2>

<div class="row g-4 mt-3">

<div class="col-md-4">
<div class="course-card">
<h5>Web Development</h5>
<p>Learn HTML, CSS and JavaScript from scratch.</p>
<a href="/viewcourse" class="btn-outline">Explore</a>
</div>
</div>

<div class="col-md-4">
<div class="course-card">
<h5>Python Programming</h5>
<p>Build real world applications with Python.</p>
<a href="/viewcourse" class="btn-outline">Explore</a>
</div>
</div>

<div class="col-md-4">
<div class="course-card">
<h5>Data Structures</h5>
<p>Master algorithms and problem solving.</p>
<a href="/viewcourse" class="btn-outline">Explore</a>
</div>
</div>

</div>

<div class="text-center mt-4">
<a href="/viewcourse" class="btn-main">View All Courses</a>
</div>

</div>

</section>


<!-- ABOUT -->

<section class="about">

<div class="container text-center">

<h2 class="section-title">About EduTrack</h2>

<p class="about-text">
EduTrack is a lightweight Learning Management System built for modern education.
It helps students learn efficiently and instructors manage courses with ease.
</p>

</div>

</section>

<%- include("footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>